# Application
NODE_ENV=production

# Ports
APP_PORT=11345
VNC_PORT=54311

# Data directory
DATA_DIR=./data

# Docker build options
INSTALL_VNC=1

# Playwright browsers to install
PLAYWRIGHT_BROWSERS=chromium firefox webkit

# Playwright runtime flags
DOPPELGANGER_SKIP_PLAYWRIGHT_INSTALL=1
PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD=1

# Security / session settings
SESSION_COOKIE_SECURE=1
TRUST_PROXY=1
SESSION_SECRET=yourcode
